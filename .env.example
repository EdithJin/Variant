# --- Anthropic (production) ---
ANTHROPIC_API_KEY=your_key_here

# --- Groq (free tier, for testing) ---
# Sign up at console.groq.com — no credit card needed
# GROQ_API_KEY=your_groq_key_here

# Set provider: "anthropic" (default) or "groq"
# LLM_PROVIDER=groq

# Optional: override model directly
# REASONING_MODEL=llama-3.3-70b-versatile

# --- LangSmith tracing (optional, free tier at smith.langchain.com) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=variant-poc
